<main class="main">
  <div class="inner">

    <% if user_signed_in? %>
      <div class="greeting">
        こんにちは、
        <%= link_to "#{current_user.name}さん",
        user_path(current_user.id),
        class: :greeting__link %>
      </div>
    <% end %>

    <div class="card__wrapper">

      <% @prototypes.each do |prototype| %>

        <div class="card">

          <%= link_to image_tag(prototype.image,
          class: :card__img),
          prototype_path(prototype.id) %>

          <%= link_to prototype.title,
          prototype_path(prototype.id),
          class: :card__title %>

          <p class="card__summary">
            <%= prototype.catch_copy %>
          </p>

          <%= link_to "by #{prototype.user.name}",
          user_path(prototype.user.id),
          class: :card__user %>

        </div>

      <% end %>

    </div>

  </div>
</main>