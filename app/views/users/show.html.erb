<main class="main">
  <div class="inner">

    <div class="user__wrapper">

      <h2 class="page-heading">
        <%= "#{@user.name}さんの情報" %>
      </h2>

      <table class="table">

        <tbody>

          <tr>
            <th class="table__col1">名前</th>
            <td class="table__col2"><%= @user.name %></td>
          </tr>

          <tr>
            <th class="table__col1">プロフィール</th>
            <td class="table__col2">よろしくお願いします。</td>
          </tr>

        </tbody>

      </table>

      <h2 class="page-heading">
        <%= "#{@user.name}さんのプロトタイプ" %>
      </h2>

      <div class="user__card">

        <% @prototypes.each do |prototype| %>

          <div class="card">

            <%= link_to image_tag(prototype.image, class: :card__img ),
            prototype_path(prototype.id) %>

            <%= link_to prototype.title,
            prototype_path(prototype.id),
            class: :card__title %>

            <p class="card__summary">
              <%= prototype.catch_copy %>
            </p>

          </div>

        <% end %>

      </div>

    </div>

  </div>
</main>